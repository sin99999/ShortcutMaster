<Window x:Class="ShortcutMaster.UI.ChipWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShortcutMaster"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False" Focusable="False"
        SizeToContent="WidthAndHeight">
    <Border CornerRadius="7"
            BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1"
            Padding="12,6" Cursor="Hand"
            MouseLeftButtonUp="OnChipClicked">
        <Border.Style>
            <Style TargetType="Border">
                <Setter Property="Background" Value="{StaticResource PanelBackgroundBrush}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{StaticResource PanelHoverBrush}" />
                    </Trigger>
                </Style.Triggers>
            </Style>
        </Border.Style>
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="⌨"
                       FontSize="12"
                       Foreground="{StaticResource AccentBrush}"
                       Margin="0,0,7,0"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="ChipLabel"
                       Text="今使えるショートカット"
                       FontSize="12"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Border>
</Window>
