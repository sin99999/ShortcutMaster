<Window x:Class="ShortcutMaster.UI.ChipWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShortcutMaster"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False" Focusable="False"
        SizeToContent="WidthAndHeight">
    <Border CornerRadius="7"
            BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1"
            Background="{StaticResource PanelBackgroundBrush}"
            Padding="4,4,2,4">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    CornerRadius="5"
                    Padding="8,2,6,2"
                    Cursor="Hand"
                    MouseLeftButtonUp="OnChipClicked">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource PanelHoverBrush}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="⌨"
                               FontSize="12"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="0,0,7,0"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="ChipLabel"
                               Text="今使えるショートカット"
                               FontSize="12"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <Button Grid.Column="1" Content="✕" FontSize="11"
                    Width="24" Height="24" Margin="0,0,2,0"
                    Focusable="False" Cursor="Hand"
                    Foreground="{StaticResource TextSecondaryBrush}"
                    ToolTip="ShortcutMaster を終了"
                    Click="OnExitClicked">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonFace" Background="Transparent" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonFace" Property="Background" Value="{StaticResource RowHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>
    </Border>
</Window>
