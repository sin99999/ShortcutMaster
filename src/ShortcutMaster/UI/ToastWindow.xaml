<Window x:Class="ShortcutMaster.UI.ToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ShortcutMaster Toast"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ShowActivated="False" Focusable="False"
        IsHitTestVisible="False"
        SizeToContent="WidthAndHeight">
    <Border CornerRadius="7"
            Background="#F2282A31"
            BorderBrush="#55FFC069" BorderThickness="1"
            Padding="12,7">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="⚠"
                       FontSize="12"
                       Foreground="#FFFFC069"
                       Margin="0,0,7,0"
                       VerticalAlignment="Center" />
            <TextBlock x:Name="MessageText"
                       FontSize="12"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       MaxWidth="320" TextWrapping="Wrap"
                       VerticalAlignment="Center" />
        </StackPanel>
    </Border>
</Window>
