<Application x:Class="ShortcutMaster.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F21B1D22" />
        <SolidColorBrush x:Key="PanelHoverBrush" Color="#F2262932" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#3DFFFFFF" />
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#FFF2F3F5" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#FF9AA3AF" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF7AA2F7" />
        <SolidColorBrush x:Key="BadgeBackgroundBrush" Color="#FF2A2D35" />
        <SolidColorBrush x:Key="BadgeBorderBrush" Color="#33FFFFFF" />
        <SolidColorBrush x:Key="RowHoverBrush" Color="#1FFFFFFF" />
    </Application.Resources>
</Application>
