{
  "app": "excel",
  "displayName": "Excel",
  "processNames": ["EXCEL"],
  "entries": [
    { "id": "xls.new", "keys": "Ctrl+N", "action": "新しいブックを作成", "category": "基本", "priority": 80, "send": ["Ctrl+N"] },
    { "id": "xls.open", "keys": "Ctrl+O", "action": "ブックを開く", "category": "基本", "priority": 82, "send": ["Ctrl+O"] },
    { "id": "xls.save", "keys": "Ctrl+S", "action": "上書き保存", "category": "基本", "priority": 98, "send": ["Ctrl+S"] },
    { "id": "xls.save-as", "keys": "F12", "action": "名前を付けて保存", "category": "基本", "priority": 84, "send": ["F12"] },
    { "id": "xls.print", "keys": "Ctrl+P", "action": "印刷画面を開く", "note": "印刷プレビューの確認にも使える", "category": "基本", "priority": 85, "send": ["Ctrl+P"] },
    { "id": "xls.copy", "keys": "Ctrl+C", "action": "選択範囲をコピー", "category": "基本", "priority": 97, "send": ["Ctrl+C"] },
    { "id": "xls.cut", "keys": "Ctrl+X", "action": "選択範囲を切り取り", "category": "基本", "priority": 93, "send": ["Ctrl+X"] },
    { "id": "xls.paste", "keys": "Ctrl+V", "action": "貼り付け", "category": "基本", "priority": 97, "send": ["Ctrl+V"] },
    { "id": "xls.paste-special", "keys": "Ctrl+Alt+V", "action": "形式を選択して貼り付け", "note": "コピー後に押す。値のみ・書式のみなど貼り付け方法を選べる", "category": "基本", "priority": 90, "send": ["Ctrl+Alt+V"] },
    { "id": "xls.undo", "keys": "Ctrl+Z", "action": "元に戻す", "category": "基本", "priority": 96, "send": ["Ctrl+Z"] },
    { "id": "xls.redo", "keys": "Ctrl+Y", "action": "やり直し", "category": "基本", "priority": 86, "send": ["Ctrl+Y"] },
    { "id": "xls.repeat", "keys": "F4", "action": "直前の操作を繰り返し", "note": "数式編集中は絶対参照・相対参照の切替", "category": "基本", "priority": 92, "send": ["F4"] },
    { "id": "xls.find", "keys": "Ctrl+F", "action": "検索ダイアログを開く", "category": "基本", "priority": 92, "send": ["Ctrl+F"] },
    { "id": "xls.replace", "keys": "Ctrl+H", "action": "置換ダイアログを開く", "category": "基本", "priority": 88, "send": ["Ctrl+H"] },
    { "id": "xls.new-sheet", "keys": "Shift+F11", "action": "新しいワークシートを挿入", "note": "現在のシートの左側に挿入される", "category": "基本", "priority": 84, "send": ["Shift+F11"] },
    { "id": "xls.jump-edge", "keys": "Ctrl+矢印キー", "action": "データ範囲の端まで移動", "note": "押した矢印の方向にあるデータの端へジャンプ", "category": "移動", "priority": 90 },
    { "id": "xls.goto-a1", "keys": "Ctrl+Home", "action": "セル A1 へ移動", "category": "移動", "priority": 91, "send": ["Ctrl+Home"] },
    { "id": "xls.goto-last", "keys": "Ctrl+End", "action": "データ範囲の右下隅へ移動", "category": "移動", "priority": 87, "send": ["Ctrl+End"] },
    { "id": "xls.sheet-next", "keys": "Ctrl+PageDown", "action": "次のシートへ移動", "category": "移動", "priority": 93, "send": ["Ctrl+PageDown"] },
    { "id": "xls.sheet-prev", "keys": "Ctrl+PageUp", "action": "前のシートへ移動", "category": "移動", "priority": 92, "send": ["Ctrl+PageUp"] },
    { "id": "xls.goto", "keys": "Ctrl+G", "action": "ジャンプダイアログを開く", "note": "F5 でも同じ。セル番地や範囲名を入力して移動", "category": "移動", "priority": 72, "send": ["Ctrl+G"] },
    { "id": "xls.row-start", "keys": "Home", "action": "行の先頭へ移動", "category": "移動", "priority": 65, "send": ["Home"] },
    { "id": "xls.screen-down", "keys": "PageDown", "action": "1画面下へスクロール", "category": "移動", "priority": 60, "send": ["PageDown"] },
    { "id": "xls.screen-up", "keys": "PageUp", "action": "1画面上へスクロール", "category": "移動", "priority": 58, "send": ["PageUp"] },
    { "id": "xls.select-all", "keys": "Ctrl+A", "action": "データ範囲・シート全体を選択", "note": "1回目はアクティブセル周辺、2回目でシート全体を選択", "category": "選択", "priority": 92, "send": ["Ctrl+A"] },
    { "id": "xls.select-col", "keys": "Ctrl+Space", "action": "列全体を選択", "category": "選択", "priority": 86, "send": ["Ctrl+Space"] },
    { "id": "xls.select-row", "keys": "Shift+Space", "action": "行全体を選択", "note": "日本語 IME がオンだと効きにくい。IME をオフにしてから押す", "category": "選択", "priority": 85, "send": ["Shift+Space"] },
    { "id": "xls.extend-one", "keys": "Shift+矢印キー", "action": "選択範囲を1セルずつ拡張", "category": "選択", "priority": 80 },
    { "id": "xls.extend-edge", "keys": "Ctrl+Shift+矢印キー", "action": "データ範囲の端まで選択を拡張", "note": "表の列・行をまとめて選択する定番操作", "category": "選択", "priority": 89 },
    { "id": "xls.extend-a1", "keys": "Ctrl+Shift+Home", "action": "セル A1 まで選択を拡張", "category": "選択", "priority": 62, "send": ["Ctrl+Shift+Home"] },
    { "id": "xls.extend-last", "keys": "Ctrl+Shift+End", "action": "データ範囲の右下隅まで選択を拡張", "category": "選択", "priority": 74, "send": ["Ctrl+Shift+End"] },
    { "id": "xls.extend-mode", "keys": "F8", "action": "選択範囲の拡張モードを切替", "note": "もう一度押すと解除", "category": "選択", "priority": 40, "send": ["F8"] },
    { "id": "xls.add-range", "keys": "Shift+F8", "action": "離れたセルを選択範囲に追加", "category": "選択", "priority": 35, "send": ["Shift+F8"] },
    { "id": "xls.edit-cell", "keys": "F2", "action": "セルを編集モードに切替", "note": "カーソルがセル内容の末尾に入る", "category": "データ入力・編集", "priority": 96, "send": ["F2"] },
    { "id": "xls.newline", "keys": "Alt+Enter", "action": "セル内で改行", "category": "データ入力・編集", "priority": 94, "send": ["Alt+Enter"] },
    { "id": "xls.fill-all", "keys": "Ctrl+Enter", "action": "選択範囲全体に一括入力", "note": "入力の確定時に押すと選択中の全セルへ同じ内容が入る", "category": "データ入力・編集", "priority": 84, "send": ["Ctrl+Enter"] },
    { "id": "xls.fill-down", "keys": "Ctrl+D", "action": "上のセルを下へコピー", "category": "データ入力・編集", "priority": 90, "send": ["Ctrl+D"] },
    { "id": "xls.fill-right", "keys": "Ctrl+R", "action": "左のセルを右へコピー", "category": "データ入力・編集", "priority": 84, "send": ["Ctrl+R"] },
    { "id": "xls.flash-fill", "keys": "Ctrl+E", "action": "フラッシュフィルで自動入力", "note": "隣の列のパターンを認識して残りを自動で埋める", "category": "データ入力・編集", "priority": 82, "send": ["Ctrl+E"] },
    { "id": "xls.today", "keys": "Ctrl+;", "action": "今日の日付を入力", "note": "日本語配列では記号位置の違いで誤送信の恐れがあるため表示のみ", "category": "データ入力・編集", "priority": 76 },
    { "id": "xls.now", "keys": "Ctrl+:", "action": "現在の時刻を入力", "note": "日本語配列では記号位置の違いで誤送信の恐れがあるため表示のみ", "category": "データ入力・編集", "priority": 70 },
    { "id": "xls.clear", "keys": "Delete", "action": "セルの内容を削除", "note": "書式は残して内容だけ消す", "category": "データ入力・編集", "priority": 78, "send": ["Delete"] },
    { "id": "xls.cancel", "keys": "Esc", "action": "入力を取り消し", "note": "コピー時の点滅枠線の解除にも使える", "category": "データ入力・編集", "priority": 74, "send": ["Esc"] },
    { "id": "xls.hyperlink", "keys": "Ctrl+K", "action": "ハイパーリンクを挿入", "category": "データ入力・編集", "priority": 64, "send": ["Ctrl+K"] },
    { "id": "xls.cell-note", "keys": "Shift+F2", "action": "セルにメモを追加・編集", "category": "データ入力・編集", "priority": 55, "send": ["Shift+F2"] },
    { "id": "xls.format-cells", "keys": "Ctrl+1", "action": "セルの書式設定を開く", "note": "表示形式・配置・罫線・塗りつぶしをまとめて設定", "category": "書式設定", "priority": 95, "send": ["Ctrl+1"] },
    { "id": "xls.bold", "keys": "Ctrl+B", "action": "太字の切替", "category": "書式設定", "priority": 90, "send": ["Ctrl+B"] },
    { "id": "xls.italic", "keys": "Ctrl+I", "action": "斜体の切替", "category": "書式設定", "priority": 78, "send": ["Ctrl+I"] },
    { "id": "xls.underline", "keys": "Ctrl+U", "action": "下線の切替", "category": "書式設定", "priority": 78, "send": ["Ctrl+U"] },
    { "id": "xls.strike", "keys": "Ctrl+5", "action": "取り消し線の切替", "category": "書式設定", "priority": 72, "send": ["Ctrl+5"] },
    { "id": "xls.fmt-number", "keys": "Ctrl+Shift+1", "action": "桁区切りの数値書式を適用", "category": "書式設定", "priority": 80, "send": ["Ctrl+Shift+1"] },
    { "id": "xls.fmt-date", "keys": "Ctrl+Shift+3", "action": "日付の表示形式を適用", "category": "書式設定", "priority": 70, "send": ["Ctrl+Shift+3"] },
    { "id": "xls.fmt-currency", "keys": "Ctrl+Shift+4", "action": "通貨の表示形式を適用", "category": "書式設定", "priority": 71, "send": ["Ctrl+Shift+4"] },
    { "id": "xls.fmt-percent", "keys": "Ctrl+Shift+5", "action": "パーセントの表示形式を適用", "category": "書式設定", "priority": 76, "send": ["Ctrl+Shift+5"] },
    { "id": "xls.border-outline", "keys": "Ctrl+Shift+6", "action": "選択範囲に外枠罫線を設定", "note": "Ctrl+Shift+&（& は Shift+6）に相当", "category": "書式設定", "priority": 68, "send": ["Ctrl+Shift+6"] },
    { "id": "xls.font-dialog", "keys": "Ctrl+Shift+F", "action": "書式設定のフォントタブを開く", "category": "書式設定", "priority": 45, "send": ["Ctrl+Shift+F"] },
    { "id": "xls.autosum", "keys": "Alt+Shift+=", "action": "オートSUMを挿入", "note": "選択位置の上または左の数値を自動で合計", "category": "数式・関数", "priority": 93, "send": ["Alt+Shift+Equals"] },
    { "id": "xls.insert-func", "keys": "Shift+F3", "action": "関数の挿入ダイアログを開く", "category": "数式・関数", "priority": 68, "send": ["Shift+F3"] },
    { "id": "xls.calc-all", "keys": "F9", "action": "すべてのブックを再計算", "category": "数式・関数", "priority": 74, "send": ["F9"] },
    { "id": "xls.calc-sheet", "keys": "Shift+F9", "action": "作業中のシートのみ再計算", "category": "数式・関数", "priority": 56, "send": ["Shift+F9"] },
    { "id": "xls.show-formulas", "keys": "Ctrl+Shift+@", "action": "数式の表示と値の表示を切替", "note": "もう一度押すと戻る。記号キーのため誤送信防止で表示のみ", "category": "数式・関数", "priority": 66 },
    { "id": "xls.formula-bar", "keys": "Ctrl+Shift+U", "action": "数式バーの展開・折りたたみ", "category": "数式・関数", "priority": 58, "send": ["Ctrl+Shift+U"] },
    { "id": "xls.macro-dialog", "keys": "Alt+F8", "action": "マクロダイアログを開く", "category": "数式・関数", "priority": 34, "send": ["Alt+F8"] },
    { "id": "xls.vba", "keys": "Alt+F11", "action": "VBA エディターを開く", "category": "数式・関数", "priority": 30, "send": ["Alt+F11"] },
    { "id": "xls.insert-cells", "keys": "Ctrl+Shift++", "action": "セル・行・列を挿入", "note": "日本語配列の + は Shift+; の位置。行・列全体を選択中は即挿入", "category": "行・列の操作", "priority": 86, "send": ["Ctrl+Shift+Plus"] },
    { "id": "xls.delete-cells", "keys": "Ctrl+-", "action": "セル・行・列を削除", "note": "行・列全体を選択中は即削除", "category": "行・列の操作", "priority": 85, "send": ["Ctrl+Minus"] },
    { "id": "xls.hide-row", "keys": "Ctrl+9", "action": "選択した行を非表示", "category": "行・列の操作", "priority": 76, "send": ["Ctrl+9"] },
    { "id": "xls.unhide-row", "keys": "Ctrl+Shift+9", "action": "非表示の行を再表示", "note": "非表示の行を挟むように上下を選択してから押す", "category": "行・列の操作", "priority": 66, "send": ["Ctrl+Shift+9"] },
    { "id": "xls.hide-col", "keys": "Ctrl+0", "action": "選択した列を非表示", "category": "行・列の操作", "priority": 75, "send": ["Ctrl+0"] },
    { "id": "xls.unhide-col", "keys": "Ctrl+Shift+0", "action": "非表示の列を再表示", "note": "効かない場合は Windows の入力切替ホットキーとの競合が原因のことがある", "category": "行・列の操作", "priority": 60, "send": ["Ctrl+Shift+0"] },
    { "id": "xls.group", "keys": "Alt+Shift+→", "action": "選択した行・列をグループ化", "note": "アウトラインとして折りたたみできるようになる", "category": "行・列の操作", "priority": 52, "send": ["Alt+Shift+Right"] },
    { "id": "xls.ungroup", "keys": "Alt+Shift+←", "action": "行・列のグループ化を解除", "category": "行・列の操作", "priority": 48, "send": ["Alt+Shift+Left"] },
    { "id": "xls.filter", "keys": "Ctrl+Shift+L", "action": "フィルターの設定と解除", "note": "もう一度押すと解除", "category": "データ・フィルター", "priority": 95, "send": ["Ctrl+Shift+L"] },
    { "id": "xls.table", "keys": "Ctrl+T", "action": "選択範囲をテーブルに変換", "note": "Ctrl+L でも同じ。作成ダイアログで範囲を確認できる", "category": "データ・フィルター", "priority": 88, "send": ["Ctrl+T"] },
    { "id": "xls.filter-menu", "keys": "Alt+↓", "action": "フィルターメニューを開く", "note": "見出しセルではフィルター、通常セルでは入力候補のリストを表示", "category": "データ・フィルター", "priority": 78, "send": ["Alt+Down"] },
    { "id": "xls.table-total", "keys": "Ctrl+Shift+T", "action": "テーブルの集計行を切替", "note": "テーブル内のセルで押す", "category": "データ・フィルター", "priority": 52, "send": ["Ctrl+Shift+T"] },
    { "id": "xls.refresh-all", "keys": "Ctrl+Alt+F5", "action": "外部データをすべて更新", "note": "ピボットテーブルやクエリの更新に使う", "category": "データ・フィルター", "priority": 46, "send": ["Ctrl+Alt+F5"] },
    { "id": "xls.quick-analysis", "keys": "Ctrl+Q", "action": "クイック分析を表示", "note": "選択データへのおすすめグラフや条件付き書式を提案", "category": "データ・フィルター", "priority": 54, "send": ["Ctrl+Q"] },
    { "id": "xls.chart", "keys": "Alt+F1", "action": "埋め込みグラフを作成", "note": "現在のデータ範囲からグラフを自動作成", "category": "データ・フィルター", "priority": 70, "send": ["Alt+F1"] },
    { "id": "xls.chart-sheet", "keys": "F11", "action": "グラフシートを作成", "category": "データ・フィルター", "priority": 44, "send": ["F11"] },
    { "id": "xls.close-book", "keys": "Ctrl+W", "action": "ブックを閉じる", "note": "Excel 自体は終了しない", "category": "表示・ウィンドウ", "priority": 78, "send": ["Ctrl+W"] },
    { "id": "xls.quit", "keys": "Alt+F4", "action": "Excel を終了", "note": "未保存の変更があれば確認が表示される。パネルからの自動実行はできません", "category": "表示・ウィンドウ", "priority": 40 },
    { "id": "xls.ribbon", "keys": "Ctrl+F1", "action": "リボンの表示・非表示を切替", "note": "もう一度押すと戻る", "category": "表示・ウィンドウ", "priority": 56, "send": ["Ctrl+F1"] },
    { "id": "xls.fullscreen", "keys": "Ctrl+Shift+F1", "action": "全画面表示の切替", "category": "表示・ウィンドウ", "priority": 34, "send": ["Ctrl+Shift+F1"] },
    { "id": "xls.zoom", "keys": "Ctrl+マウスホイール", "action": "表示倍率を変更", "category": "表示・ウィンドウ", "priority": 72 },
    { "id": "xls.next-book", "keys": "Ctrl+Tab", "action": "次のブックへ切替", "note": "複数のブックを開いている時に使う", "category": "表示・ウィンドウ", "priority": 62, "send": ["Ctrl+Tab"] },
    { "id": "xls.pane-switch", "keys": "F6", "action": "ワークシート・リボン・作業ウィンドウ間を移動", "category": "表示・ウィンドウ", "priority": 36, "send": ["F6"] },
    { "id": "xls.rib-home", "keys": "Alt, H", "action": "ホームタブを開く", "note": "Alt に続けて英字を順に押す。画面にキーヒントが表示される", "category": "リボン操作(Alt)", "priority": 74, "send": ["Alt", "H"] },
    { "id": "xls.rib-insert", "keys": "Alt, N", "action": "挿入タブを開く", "category": "リボン操作(Alt)", "priority": 60, "send": ["Alt", "N"] },
    { "id": "xls.rib-data", "keys": "Alt, A", "action": "データタブを開く", "category": "リボン操作(Alt)", "priority": 62, "send": ["Alt", "A"] },
    { "id": "xls.rib-view", "keys": "Alt, W", "action": "表示タブを開く", "category": "リボン操作(Alt)", "priority": 56, "send": ["Alt", "W"] },
    { "id": "xls.rib-border", "keys": "Alt, H, B", "action": "罫線メニューを開く", "category": "リボン操作(Alt)", "priority": 78, "send": ["Alt", "H", "B"] },
    { "id": "xls.rib-fill", "keys": "Alt, H, H", "action": "塗りつぶしの色メニューを開く", "category": "リボン操作(Alt)", "priority": 76, "send": ["Alt", "H", "H"] },
    { "id": "xls.rib-font-color", "keys": "Alt, H, F, C", "action": "フォントの色メニューを開く", "category": "リボン操作(Alt)", "priority": 70, "send": ["Alt", "H", "F", "C"] },
    { "id": "xls.rib-center", "keys": "Alt, H, A, C", "action": "中央揃えを適用", "category": "リボン操作(Alt)", "priority": 72, "send": ["Alt", "H", "A", "C"] },
    { "id": "xls.rib-wrap", "keys": "Alt, H, W", "action": "折り返して全体を表示", "category": "リボン操作(Alt)", "priority": 75, "send": ["Alt", "H", "W"] },
    { "id": "xls.rib-merge", "keys": "Alt, H, M, C", "action": "セルを結合して中央揃え", "category": "リボン操作(Alt)", "priority": 66, "send": ["Alt", "H", "M", "C"] },
    { "id": "xls.rib-del-col", "keys": "Alt, H, D, C", "action": "選択した列を削除", "category": "リボン操作(Alt)", "priority": 58, "send": ["Alt", "H", "D", "C"] },
    { "id": "xls.rib-clear-fmt", "keys": "Alt, H, E, F", "action": "書式をクリア", "note": "値は残して書式だけ消す", "category": "リボン操作(Alt)", "priority": 68, "send": ["Alt", "H", "E", "F"] },
    { "id": "xls.rib-cond-format", "keys": "Alt, H, L", "action": "条件付き書式メニューを開く", "category": "リボン操作(Alt)", "priority": 64, "send": ["Alt", "H", "L"] },
    { "id": "xls.rib-freeze", "keys": "Alt, W, F, F", "action": "ウィンドウ枠の固定・解除", "note": "選択セルの上と左を固定。先頭行だけなら Alt, W, F, R", "category": "リボン操作(Alt)", "priority": 84, "send": ["Alt", "W", "F", "F"] },
    { "id": "xls.rib-pivot", "keys": "Alt, N, V", "action": "ピボットテーブルを挿入", "note": "バージョンによっては続けて T を押す", "category": "リボン操作(Alt)", "priority": 70, "send": ["Alt", "N", "V"] },
    { "id": "xls.rib-sort-asc", "keys": "Alt, A, S, A", "action": "昇順で並べ替え", "category": "リボン操作(Alt)", "priority": 65, "send": ["Alt", "A", "S", "A"] }
  ]
}
