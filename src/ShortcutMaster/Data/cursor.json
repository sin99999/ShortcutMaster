    { "id": "cur.tab-next", "keys": "Ctrl+PageDown", "action": "右隣のタブへ移動", "note": "Ctrl+PageUp で左隣へ", "category": "ファイル・タブ", "priority": 48, "send": ["Ctrl+PageDown"] },
    { "id": "cur.file-copy-path", "keys": "Ctrl+K, P", "action": "アクティブファイルのパスをコピー", "note": "エディタにフォーカスがあると Ctrl+K が AI 編集になり動作しない場合がある", "category": "ファイル・タブ", "priority": 32, "send": ["Ctrl+K", "P"] },
    { "id": "cur.file-reveal", "keys": "Ctrl+K, R", "action": "ファイルをエクスプローラーで表示", "note": "エディタにフォーカスがあると Ctrl+K が AI 編集になり動作しない場合がある", "category": "ファイル・タブ", "priority": 35, "send": ["Ctrl+K", "R"] },
    { "id": "cur.window-new", "keys": "Ctrl+Shift+N", "action": "新しいウィンドウを開く", "category": "ファイル・タブ", "priority": 50, "send": ["Ctrl+Shift+N"] },
