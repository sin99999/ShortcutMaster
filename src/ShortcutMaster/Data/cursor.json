{
  "app": "cursor",
  "displayName": "Cursor",
  "processNames": ["Cursor"],
  "entries": [
    { "id": "cur.ai-inline-edit", "keys": "Ctrl+K", "action": "インライン AI 編集を開く", "note": "エディタ内で選択範囲やカーソル位置のコードを AI に指示して編集・生成できる", "category": "AI機能", "priority": 96, "send": ["Ctrl+K"] },
    { "id": "cur.ai-chat-toggle", "keys": "Ctrl+L", "action": "AI チャット（サイドパネル）の表示切り替え", "note": "コードを選択して押すと新しいチャットのコンテキストに追加される", "category": "AI機能", "priority": 95, "send": ["Ctrl+L"] },
    { "id": "cur.ai-sidepanel-toggle", "keys": "Ctrl+I", "action": "AI サイドパネルの切り替え", "note": "Agent/Composer などバージョンにより割り当てが異なる場合がある", "category": "AI機能", "priority": 88, "send": ["Ctrl+I"] },
    { "id": "cur.ai-agent-layout", "keys": "Ctrl+E", "action": "Agent レイアウトの切り替え", "note": "バージョンにより異なる場合がある", "category": "AI機能", "priority": 72, "send": ["Ctrl+E"] },
    { "id": "cur.ai-add-selection-chat", "keys": "Ctrl+Shift+L", "action": "選択コードをチャットに追加", "note": "VS Code 標準の全一致選択から Cursor 用に変更されている", "category": "AI機能", "priority": 85, "send": ["Ctrl+Shift+L"] },
    { "id": "cur.ai-add-selection-edit", "keys": "Ctrl+Shift+K", "action": "選択コードをインライン編集（Edit）に追加", "note": "VS Code 標準では行削除。行削除は未選択時の Ctrl+X で代替できる", "category": "AI機能", "priority": 78, "send": ["Ctrl+Shift+K"] },
    { "id": "cur.ai-settings", "keys": "Ctrl+Shift+J", "action": "Cursor 設定を開く", "note": "AI モデルやルールなど Cursor 固有の設定画面", "category": "AI機能", "priority": 80, "send": ["Ctrl+Shift+J"] },
    { "id": "cur.ai-tab-accept", "keys": "Tab", "action": "AI 補完（Cursor Tab）の候補を受け入れ", "note": "補完候補の表示中のみ有効。通常時はタブ入力になるため表示のみ", "category": "AI機能", "priority": 90 },
    { "id": "cur.ai-accept-word", "keys": "Ctrl+Right", "action": "AI 補完を 1 単語ずつ受け入れ", "note": "補完候補の表示中のみ有効。通常時は単語単位のカーソル移動のため表示のみ", "category": "AI機能", "priority": 60 },
    { "id": "cur.ai-cancel-generation", "keys": "Ctrl+Shift+Backspace", "action": "AI 生成のキャンセル", "note": "チャットの応答生成やインライン編集を中断する", "category": "AI機能", "priority": 62, "send": ["Ctrl+Shift+Backspace"] },
    { "id": "cur.ai-voice-mode", "keys": "Ctrl+Shift+Space", "action": "音声モードの切り替え", "note": "バージョンにより異なる場合がある（VS Code 標準ではパラメーターヒント表示）", "category": "AI機能", "priority": 40, "send": ["Ctrl+Shift+Space"] },
    { "id": "cur.ai-quick-question", "keys": "Alt+Enter", "action": "インライン編集でクイック質問", "note": "Ctrl+K のインライン編集を開いた状態で使うため表示のみ", "category": "AI機能", "priority": 45 },
    { "id": "cur.edit-copy", "keys": "Ctrl+C", "action": "コピー", "note": "選択がないときは現在行をコピー", "category": "基本編集", "priority": 98, "send": ["Ctrl+C"] },
    { "id": "cur.edit-cut", "keys": "Ctrl+X", "action": "切り取り", "note": "選択がないときは現在行を切り取り（行削除の代替。Ctrl+Shift+K は AI に割り当て）", "category": "基本編集", "priority": 97, "send": ["Ctrl+X"] },
    { "id": "cur.edit-paste", "keys": "Ctrl+V", "action": "貼り付け", "category": "基本編集", "priority": 98, "send": ["Ctrl+V"] },
    { "id": "cur.edit-undo", "keys": "Ctrl+Z", "action": "元に戻す", "category": "基本編集", "priority": 98, "send": ["Ctrl+Z"] },
    { "id": "cur.edit-redo", "keys": "Ctrl+Y", "action": "やり直し", "note": "Ctrl+Shift+Z でも可", "category": "基本編集", "priority": 88, "send": ["Ctrl+Y"] },
    { "id": "cur.edit-select-all", "keys": "Ctrl+A", "action": "すべて選択", "category": "基本編集", "priority": 94, "send": ["Ctrl+A"] },
    { "id": "cur.edit-line-comment", "keys": "Ctrl+/", "action": "行コメントの切り替え", "note": "チャット入力欄では AI モデルの切り替えに使用", "category": "基本編集", "priority": 88, "send": ["Ctrl+Slash"] },
    { "id": "cur.edit-block-comment", "keys": "Shift+Alt+A", "action": "ブロックコメントの切り替え", "category": "基本編集", "priority": 50, "send": ["Shift+Alt+A"] },
    { "id": "cur.edit-format-document", "keys": "Shift+Alt+F", "action": "ドキュメント全体をフォーマット", "category": "基本編集", "priority": 72, "send": ["Shift+Alt+F"] },
    { "id": "cur.edit-trigger-suggest", "keys": "Ctrl+Space", "action": "補完候補の表示（IntelliSense）", "note": "IME の切り替えに割り当てている環境では競合する場合がある", "category": "基本編集", "priority": 55, "send": ["Ctrl+Space"] },
    { "id": "cur.edit-indent", "keys": "Ctrl+] / Ctrl+[", "action": "行のインデントを追加・削除", "note": "日本語配列ではキー位置が異なるため表示のみ", "category": "基本編集", "priority": 55 },
    { "id": "cur.line-move-up", "keys": "Alt+Up", "action": "行を上へ移動", "category": "行・カーソル操作", "priority": 86, "send": ["Alt+Up"] },
    { "id": "cur.line-move-down", "keys": "Alt+Down", "action": "行を下へ移動", "category": "行・カーソル操作", "priority": 86, "send": ["Alt+Down"] },
    { "id": "cur.line-copy-up", "keys": "Shift+Alt+Up", "action": "行を上へ複製", "category": "行・カーソル操作", "priority": 76, "send": ["Shift+Alt+Up"] },
    { "id": "cur.line-copy-down", "keys": "Shift+Alt+Down", "action": "行を下へ複製", "category": "行・カーソル操作", "priority": 80, "send": ["Shift+Alt+Down"] },
    { "id": "cur.multi-select-next", "keys": "Ctrl+D", "action": "次の一致を選択（マルチカーソル）", "note": "押すたびに同じ単語を追加選択し、まとめて編集できる", "category": "行・カーソル操作", "priority": 90, "send": ["Ctrl+D"] },
    { "id": "cur.line-insert-below", "keys": "Ctrl+Enter", "action": "現在行の下に行を挿入", "category": "行・カーソル操作", "priority": 66, "send": ["Ctrl+Enter"] },
    { "id": "cur.line-insert-above", "keys": "Ctrl+Shift+Enter", "action": "現在行の上に行を挿入", "category": "行・カーソル操作", "priority": 55, "send": ["Ctrl+Shift+Enter"] },
    { "id": "cur.multi-cursor-up", "keys": "Ctrl+Alt+Up", "action": "上にカーソルを追加", "note": "環境により画面回転のショートカットと競合する場合がある", "category": "行・カーソル操作", "priority": 58, "send": ["Ctrl+Alt+Up"] },
    { "id": "cur.multi-cursor-down", "keys": "Ctrl+Alt+Down", "action": "下にカーソルを追加", "note": "環境により画面回転のショートカットと競合する場合がある", "category": "行・カーソル操作", "priority": 60, "send": ["Ctrl+Alt+Down"] },
    { "id": "cur.multi-cursor-click", "keys": "Alt+クリック", "action": "クリック位置にカーソルを追加", "note": "マウス併用のため表示のみ", "category": "行・カーソル操作", "priority": 74 },
    { "id": "cur.select-expand", "keys": "Shift+Alt+Right", "action": "選択範囲を段階的に拡大", "note": "Shift+Alt+Left で縮小", "category": "行・カーソル操作", "priority": 48, "send": ["Shift+Alt+Right"] },
    { "id": "cur.nav-quick-open", "keys": "Ctrl+P", "action": "ファイル名で検索して開く", "category": "移動・ジャンプ", "priority": 97, "send": ["Ctrl+P"] },
    { "id": "cur.nav-command-palette", "keys": "Ctrl+Shift+P", "action": "コマンドパレットを開く", "note": "すべてのコマンドを検索して実行できる。F1 でも可", "category": "移動・ジャンプ", "priority": 96, "send": ["Ctrl+Shift+P"] },
    { "id": "cur.nav-goto-line", "keys": "Ctrl+G", "action": "指定行へ移動", "category": "移動・ジャンプ", "priority": 75, "send": ["Ctrl+G"] },
