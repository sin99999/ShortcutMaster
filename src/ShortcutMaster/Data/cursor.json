    { "id": "cur.view-output", "keys": "Ctrl+Shift+U", "action": "出力パネルの表示切り替え", "category": "表示・パネル", "priority": 40, "send": ["Ctrl+Shift+U"] },
    { "id": "cur.view-split", "keys": "Ctrl+\\", "action": "エディタを左右に分割", "note": "日本語配列では ￥ キーを使用", "category": "表示・パネル", "priority": 70, "send": ["Ctrl+Backslash"] },
    { "id": "cur.view-editor-group", "keys": "Ctrl+1", "action": "分割したエディタ間を移動", "note": "Ctrl+2、Ctrl+3 で各グループへ", "category": "表示・パネル", "priority": 48, "send": ["Ctrl+1"] },
    { "id": "cur.view-zen", "keys": "Ctrl+K, Z", "action": "禅モード（集中表示）の切り替え", "note": "Esc を 2 回押すと解除。動作しない場合はコマンドパレットから", "category": "表示・パネル", "priority": 30, "send": ["Ctrl+K", "Z"] },
    { "id": "cur.view-fullscreen", "keys": "F11", "action": "全画面表示の切り替え", "note": "デバッグ中はステップインに使用される", "category": "表示・パネル", "priority": 52, "send": ["F11"] },
    { "id": "cur.view-zoom", "keys": "Ctrl++ / Ctrl+-", "action": "表示全体の拡大・縮小", "note": "日本語配列では記号位置が異なるため表示のみ", "category": "表示・パネル", "priority": 58 },
    { "id": "cur.term-toggle", "keys": "Ctrl+`", "action": "ターミナルの表示切り替え", "note": "日本語配列では @ キーの位置になるため表示のみ。Ctrl+J のパネル切り替えで代替可", "category": "ターミナル", "priority": 85 },
    { "id": "cur.term-new", "keys": "Ctrl+Shift+`", "action": "新しいターミナルを作成", "note": "日本語配列では @ キーの位置になるため表示のみ", "category": "ターミナル", "priority": 55 },
    { "id": "cur.term-ai-prompt", "keys": "Ctrl+K", "action": "ターミナル AI プロンプトバーを開く", "note": "ターミナルにフォーカスがあるとき。自然言語からコマンドを生成できる", "category": "ターミナル", "priority": 55, "send": ["Ctrl+K"] },
    { "id": "cur.term-split", "keys": "Ctrl+Shift+5", "action": "ターミナルを分割", "note": "ターミナルにフォーカスがあるとき", "category": "ターミナル", "priority": 32, "send": ["Ctrl+Shift+5"] },
    { "id": "cur.misc-rename", "keys": "F2", "action": "シンボル名を一括変更（リネーム）", "category": "その他", "priority": 78, "send": ["F2"] },
    { "id": "cur.misc-quick-fix", "keys": "Ctrl+.", "action": "クイックフィックス（修正候補の表示）", "note": "チャット入力欄ではモードメニュー", "category": "その他", "priority": 66, "send": ["Ctrl+Period"] },
    { "id": "cur.misc-shortcuts", "keys": "Ctrl+K, Ctrl+S", "action": "キーボードショートカット一覧を開く", "note": "Ctrl+K が AI 編集と競合して動作しない場合はコマンドパレットから開く", "category": "その他", "priority": 60, "send": ["Ctrl+K", "Ctrl+S"] },
    { "id": "cur.misc-settings", "keys": "Ctrl+,", "action": "設定を開く", "note": "Cursor 固有の設定は Ctrl+Shift+J", "category": "その他", "priority": 72, "send": ["Ctrl+Comma"] },
    { "id": "cur.misc-next-problem", "keys": "F8", "action": "次のエラー・警告へ移動", "note": "Shift+F8 で前へ", "category": "その他", "priority": 46, "send": ["F8"] },
    { "id": "cur.misc-debug-start", "keys": "F5", "action": "デバッグの開始・続行", "category": "その他", "priority": 58, "send": ["F5"] },
    { "id": "cur.misc-breakpoint", "keys": "F9", "action": "ブレークポイントの切り替え", "category": "その他", "priority": 52, "send": ["F9"] },
    { "id": "cur.misc-step-over", "keys": "F10", "action": "ステップオーバー（デバッグ中）", "note": "F11 でステップイン、Shift+F11 でステップアウト", "category": "その他", "priority": 44, "send": ["F10"] }
  ]
